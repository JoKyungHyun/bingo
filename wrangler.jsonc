{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bingo",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-29",
  "assets": {
    "binding": "ASSETS",
    "directory": "./public"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bingo-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "bingo-photos"
    }
  ]
}
